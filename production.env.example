# ==============================================================================
# Production Environment Configuration Template for JK Fluid Controls CRM
# ==============================================================================

# Server settings
HOST=0.0.0.0
PORT=8765
DB_ENGINE=postgres
AUTO_FALLBACK_SQLITE=false

# Supabase Production Database URL
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]?sslmode=require
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres?sslmode=require

# JWT Production Secrets (DO NOT use default values!)
# Generate cryptographically secure keys: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ACCESS_SECRET=your_super_secret_production_access_key
JWT_REFRESH_SECRET=your_super_secret_production_refresh_key

# OpenAI API Integration (For AI assistant, smart WhatsApp replies, email drafts)
OPENAI_API_KEY=sk-proj-your_production_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_INSECURE_TLS=false

# Production Email SMTP settings (SMTP / App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_email@gmail.com

# Meta WhatsApp Cloud API Integration
META_WHATSAPP_TOKEN=your_meta_whatsapp_token
META_PHONE_NUMBER_ID=your_phone_number_id

# Twilio WhatsApp API Backup Integration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_INSECURE_TLS=false
